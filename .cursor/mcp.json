{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "nuxt": {
      "url": "https://nuxt.com/mcp"
    },
    "nuxt-ui": {
      "url": "https://ui.nuxt.com/mcp"
    },
    "better-auth": {
